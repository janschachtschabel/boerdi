{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/boerdi/browser",
  "rewrites": [
    {
      "source": "/mcp-proxy/:path*",
      "destination": "https://learn.microsoft.com/api/mcp/:path*"
    },
    {
      "source": "/mcp-proxy",
      "destination": "https://learn.microsoft.com/api/mcp"
    },
    {
      "source": "/bapi-proxy/:path*",
      "destination": "https://b-api.staging.openeduhub.net/api/v1/llm/openai/:path*"
    },
    {
      "source": "/bapi-proxy",
      "destination": "https://b-api.staging.openeduhub.net/api/v1/llm/openai"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
